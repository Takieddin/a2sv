class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        longest = strs[0]
        minidx = float("inf")
        if len(strs) == 1:
            return longest
        for word in strs[1:]:
            i = 0
            for c in word:
                if i < len(longest ) and c == longest[i]:
                    i += 1
                else:
                    minidx = min(i,minidx)
                    break
            minidx = min(i,minidx)
        return longest[:minidx ] if minidx != float("+inf") else ""

        